# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=                              # run: openssl rand -hex 32
ENVIRONMENT=development                  # development | production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=releasewatch
POSTGRES_USER=rw_user
POSTGRES_PASSWORD=                       # set a strong password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
# For AWS S3: leave S3_ENDPOINT_URL empty and set S3_REGION
# For MinIO:  set S3_ENDPOINT_URL to your MinIO server URL
S3_ENDPOINT_URL=                         # e.g. https://minio.example.com
S3_BUCKET_NAME=releasewatch
S3_ACCESS_KEY=                           # your access key
S3_SECRET_KEY=                           # your secret key
S3_REGION=us-east-1
S3_PRESIGN_EXPIRY=3600
S3_USE_PRESIGNED=true
S3_PUBLIC_URL_BASE=
S3_LARGE_FILE_THRESHOLD_MB=100
S3_LARGE_FILE_RETENTION_DAYS=60

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                      # from @BotFather
TELEGRAM_BOT_USERNAME=                   # e.g. MyBot
FRONTEND_URL=http://localhost:8080       # used in Telegram deep links

# ── Admin bootstrap ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=                          # set by deploy.sh on first deploy; change after first login

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
