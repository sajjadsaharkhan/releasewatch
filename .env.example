# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ENVIRONMENT=development                  # development | production
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=releasewatch
POSTGRES_USER=rw_user
POSTGRES_PASSWORD=change-me

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
# For AWS S3: Leave S3_ENDPOINT_URL empty and set S3_REGION
# For MinIO: Set S3_ENDPOINT_URL to your MinIO server URL
S3_ENDPOINT_URL=                        # e.g., https://minio.example.com for MinIO
S3_BUCKET_NAME=releasewatch
S3_ACCESS_KEY=minioadmin                # Your access key
S3_SECRET_KEY=minioadmin                # Your secret key
S3_REGION=us-east-1                     # Region (can be empty for MinIO)
S3_PRESIGN_EXPIRY=3600                  # Pre-signed URL lifetime in seconds
S3_USE_PRESIGNED=true                   # If false, generates public URLs (requires S3_PUBLIC_URL_BASE)
S3_PUBLIC_URL_BASE=                     # Base URL for public access (e.g., CDN URL)
S3_LARGE_FILE_THRESHOLD_MB=100          # Files above this size get auto-deletion
S3_LARGE_FILE_RETENTION_DAYS=60         # Days before large files are auto-deleted

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_USERNAME=ReleasewatchBot

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
