# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=                              # openssl rand -hex 32
ENVIRONMENT=production
ALLOWED_ORIGINS=https://yourdomain.com  # comma-separated if multiple

# ── Image tag (set by deploy.sh or manually) ──────────────────────────────────
IMAGE_TAG=latest                         # or a specific git SHA

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=releasewatch
POSTGRES_USER=rw_user
POSTGRES_PASSWORD=                       # use a strong random password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=                         # leave empty for AWS S3, set for MinIO
S3_BUCKET_NAME=releasewatch
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PRESIGN_EXPIRY=3600
S3_USE_PRESIGNED=true
S3_PUBLIC_URL_BASE=
S3_LARGE_FILE_THRESHOLD_MB=100
S3_LARGE_FILE_RETENTION_DAYS=60

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
FRONTEND_URL=https://yourdomain.com

# ── Admin bootstrap ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=                          # auto-generated by deploy.sh on first deploy; change after first login

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
